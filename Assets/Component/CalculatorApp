// ─── Graph ─────────────────────────────────────────────────────────────────────
const G_STEPS = 60
const G_H = 130

function buildPts(amount: number, rate: number, autoOn: boolean) {
    return Array.from({ length: G_STEPS + 1 }, (_, i) => ({
        i,
        v: autoOn
            ? amount * Math.pow(1 + rate / 100, i)
            : amount * Math.max(1 - i * 0.002, 0.1),
    }))
}

function toXY(pts: { i: number; v: number }[], W: number, pt = 14, pb = 24) {
    const vals = pts.map((p) => p.v)
    const minV = Math.min(...vals)
    const rng = Math.max(...vals) - minV || 1
    return pts.map((p) => ({
        x: (p.i / G_STEPS) * W,
        y: G_H - pb - ((p.v - minV) / rng) * (G_H - pt - pb),
    }))
}

function catmullPath(pts: { x: number; y: number }[], close = false, t = 0.3) {
    if (!pts.length) return ""
    let d = `M${pts[0].x.toFixed(1)},${pts[0].y.toFixed(1)}`
    for (let i = 0; i < pts.length - 1; i++) {
        const p0 = pts[Math.max(i - 1, 0)]
        const p1 = pts[i],
            p2 = pts[i + 1]
        const p3 = pts[Math.min(i + 2, pts.length - 1)]
        const cx1 = p1.x + (p2.x - p0.x) * t
        const cy1 = p1.y + (p2.y - p0.y) * t
        const cx2 = p2.x - (p3.x - p1.x) * t
        const cy2 = p2.y - (p3.y - p1.y) * t
        d += ` C${cx1.toFixed(1)},${cy1.toFixed(1)} ${cx2.toFixed(1)},${cy2.toFixed(1)} ${p2.x.toFixed(1)},${p2.y.toFixed(1)}`
    }
    if (close) d += ` L${pts[pts.length - 1].x.toFixed(1)},${G_H} L0,${G_H} Z`
    return d
}

function Graph({
    amount,
    monthlyRate,
    autoOn,
    isRTL,
}: {
    amount: number
    monthlyRate: number
    autoOn: boolean
    isRTL: boolean
}) {
    const wrapRef = useRef<HTMLDivElement>(null)
    const [w, setW] = useState(400)

    useEffect(() => {
        if (!wrapRef.current) return
        setW(wrapRef.current.getBoundingClientRect().width)
        const ro = new ResizeObserver(([e]) => setW(e.contentRect.width))
        ro.observe(wrapRef.current)
        return () => ro.disconnect()
    }, [])

    const pts = toXY(buildPts(amount, monthlyRate, autoOn), w)
    const line = catmullPath(pts)
    const fill = catmullPath(pts, true)

    return (
        <div ref={wrapRef} style={{ width: "100%", height: G_H }}>
            <svg
                viewBox={`0 0 ${w} ${G_H}`}
                width="100%"
                height={G_H}
                preserveAspectRatio="none"
                style={{
                    display: "block",
                    overflow: "visible",
                    // Mirror horizontally for RTL so curve grows right → left
                    transform: isRTL ? "scaleX(-1)" : "none",
                    transformOrigin: "center center",
                }}
            >
                <defs>
                    <linearGradient id="g-line" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stopColor="rgba(255,255,255,0.25)" />
                        <stop offset="35%" stopColor="#D5C0A7" />
                        <stop offset="65%" stopColor="#C7D1CB" />
                        <stop offset="100%" stopColor="#ffffff" />
                    </linearGradient>
                    <linearGradient id="g-fill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stopColor="rgba(197,217,228,0.22)" />
                        <stop offset="100%" stopColor="rgba(197,217,228,0)" />
                    </linearGradient>
                </defs>
                <path d={fill} fill="url(#g-fill)" />
                <path
                    d={line}
                    fill="none"
                    stroke="url(#g-line)"
                    strokeWidth={3.5}
                    strokeLinecap="round"
                    strokeLinejoin="round"
                />
            </svg>
        </div>
    )
}

