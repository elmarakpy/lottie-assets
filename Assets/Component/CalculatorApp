}

function NativeSlider({
    value,
    min,
    max,
    step = 100,
    accentColor,
    onChange,
    isRTL,
}: {
    value: number
    min: number
    max: number
    step?: number
    accentColor: string
    onChange: (v: number) => void
    isRTL: boolean
}) {
    useEffect(() => { injectSliderCSS() }, [])

    // key= forces a full remount when min/max/defaultValue change externally.
    // Inside a drag, none of these change — so the input is never remounted
    // mid-drag and the browser owns the thumb position 100%.
    const mountKey = `${min}-${max}-${value}`

    const handleInput = (e: React.ChangeEvent<HTMLInputElement>) => {
        const v = Number(e.target.value)
        const pct = Math.round(((v - min) / (max - min)) * 100)
        e.target.style.background = `linear-gradient(to right,
            ${accentColor} ${pct}%,
            rgba(120,120,120,0.30) ${pct}%)`
        onChange(v)
    }

    const initPct = Math.round(((value - min) / (max - min)) * 100)
    const initBg = `linear-gradient(to right,
        ${accentColor} ${initPct}%,
        rgba(120,120,120,0.30) ${initPct}%)`

    return (
        <div style={{
            width: "100%",
            padding: "8px 0",
            flexShrink: 0,
            direction: "ltr", // always LTR — RTL is handled by fill swap below
        }}>
            <input
                key={mountKey}
                type="range"
                className="inv-slider"
                min={min}
                max={max}
                step={step}
                defaultValue={value}
                style={{
                    background: initBg,
                    direction: "ltr",
                    // RTL: flip fill direction visually via scaleX
                    transform: isRTL ? "scaleX(-1)" : "none",
                }}
                onChange={handleInput}
            />
        </div>
    )
}

// ─── Pointer Slider ────────────────────────────────────────────────────────────
// Uses setPointerCapture — most reliable drag primitive in browser/Framer.
// No native <input>, no window listeners, no stale closures.

function PointerSlider({
    value,
    min,
    max,
    step = 100,
    accentColor,
    onChange,
    isRTL,
}: {
    value: number
    min: number
    max: number
    step?: number
    accentColor: string
    onChange: (v: number) => void
    isRTL: boolean
}) {
    const trackRef = useRef<HTMLDivElement>(null)

    const pct = Math.max(0, Math.min(1, (value - min) / (max - min)))

    const valueFromPointer = (e: React.PointerEvent) => {
        const rect = trackRef.current!.getBoundingClientRect()
        let ratio = (e.clientX - rect.left) / rect.width
        if (isRTL) ratio = 1 - ratio
        ratio = Math.max(0, Math.min(1, ratio))
        const raw = ratio * (max - min) + min
        return Math.max(min, Math.min(max, Math.round(raw / step) * step))
    }

    const onPointerDown = (e: React.PointerEvent<HTMLDivElement>) => {
        e.currentTarget.setPointerCapture(e.pointerId)
        onChange(valueFromPointer(e))
    }

    const onPointerMove = (e: React.PointerEvent<HTMLDivElement>) => {
        if (!e.currentTarget.hasPointerCapture(e.pointerId)) return
        onChange(valueFromPointer(e))
    }

    const onKeyDown = (e: React.KeyboardEvent) => {
        if (e.key === "ArrowRight") onChange(Math.min(max, value + step))
        if (e.key === "ArrowLeft")  onChange(Math.max(min, value - step))
    }

    const TRACK_H = 6
    const THUMB_W = 38
    const THUMB_H = 24

    return (
        <div
            ref={trackRef}
            role="slider"
            tabIndex={0}
            aria-valuemin={min}
            aria-valuemax={max}
            aria-valuenow={value}
            onPointerDown={onPointerDown}
            onPointerMove={onPointerMove}
            onKeyDown={onKeyDown}
            style={{
                position: "relative",
                width: "100%",
                height: THUMB_H + 16,
                display: "flex",
                alignItems: "center",
                cursor: "pointer",
                userSelect: "none",
                WebkitUserSelect: "none",
                touchAction: "none",
                outline: "none",
                flexShrink: 0,
            }}
        >
            {/* Track background */}
            <div style={{
                position: "absolute",
                left: 0, right: 0,
                height: TRACK_H,
                borderRadius: TRACK_H / 2,
                background: "rgba(120,120,120,0.28)",
                pointerEvents: "none",
            }} />

            {/* Active fill */}
            <div style={{
                position: "absolute",
                left: isRTL ? `${(1 - pct) * 100}%` : 0,
                right: isRTL ? 0 : `${(1 - pct) * 100}%`,
                height: TRACK_H,
                borderRadius: TRACK_H / 2,
                background: accentColor,
                pointerEvents: "none",
            }} />

            {/* Tick marks */}
            {[0, 0.25, 0.5, 0.75, 1].map(t => (
                <div key={t} style={{
                    position: "absolute",
                    left: `${t * 100}%`,
                    top: "50%",
                    transform: "translate(-50%, -50%)",
                    width: 4, height: 4,
                    borderRadius: "50%",
                    background: "rgba(60,60,67,0.25)",
                    pointerEvents: "none",
                }} />
            ))}

            {/* Pill thumb — clamped so it never overflows edges */}
            <div style={{
                position: "absolute",
                left: `clamp(0px, calc(${pct * 100}% - ${THUMB_W / 2}px), calc(100% - ${THUMB_W}px))`,
                width: THUMB_W,
                height: THUMB_H,
                borderRadius: 100,
                background: "#ffffff",
                boxShadow: "0 6px 13px rgba(0,0,0,0.15), 0 0.5px 4px rgba(0,0,0,0.12)",
                pointerEvents: "none",
            }} />
        </div>
    )
}


// ─── Animated Number ───────────────────────────────────────────────────────────
function AnimNum({
    value,
    size,
    iconSize,
    uid,
    compact = false,
    isRTL,
}: {
    value: number
    size: number
    iconSize: number
    uid: string
    compact?: boolean
    isRTL: boolean
}) {
    const display = compact ? fmtCompact(value) : fmtFull(value)
    return (
        <div
            style={{
                display: "flex",
                alignItems: "center",
                gap: 6,
                minWidth: 0,
                flexDirection: isRTL ? "row-reverse" : "row",
            }}
        >
            <RiyalIcon size={iconSize} gradient uid={uid} />
            <AnimatePresence mode="wait">
                <motion.span
                    key={display}
                    initial={{ opacity: 0, y: 5 }}
                    animate={{ opacity: 1, y: 0 }}
                    exit={{ opacity: 0, y: -5 }}
                    transition={{ duration: 0.12 }}
                    style={{
                        fontSize: size,
                        fontWeight: 500,
                        letterSpacing: "-0.04em",
                        lineHeight: 1,
                        whiteSpace: "nowrap",
                        ...GRAD_TEXT,
                    }}
                >
                    {display}
                </motion.span>
            </AnimatePresence>
        </div>
    )
}

