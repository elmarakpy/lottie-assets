                        justifyContent: "space-between",
                        alignItems: "flex-end",
                        gap: 12,
                        flexShrink: 0,
                        flexWrap: "wrap",
                    }}
                >
                    <div
                        style={{
                            display: "flex",
                            flexDirection: "column",
                            gap: 12,
                            minWidth: 0,
                        }}
                    >
                        <span
                            style={{
                                fontSize: 16,
                                color: labelColor,
                                lineHeight: "140%",
                            }}
                        >
                            {labelIfYouInvest}
                        </span>
                        <div
                            style={{
                                display: "flex",
                                alignItems: "center",
                                gap: 8,
                                minWidth: 0,
                                flexDirection: isRTL ? "row-reverse" : "row",
                            }}
                        >
                            <RiyalIcon
                                size={isMobile ? 28 : 42}
                                gradient
                                uid="input"
                            />
                            <AnimatePresence mode="wait">
                                <motion.span
                                    key={fmtFull(amount)}
                                    initial={{ opacity: 0, y: 6 }}
                                    animate={{ opacity: 1, y: 0 }}
                                    exit={{ opacity: 0, y: -6 }}
                                    transition={{ duration: 0.14 }}
                                    style={{
                                        fontSize: isMobile
                                            ? 36
                                            : "clamp(32px,4vw,52px)",
                                        fontWeight: 400,
                                        letterSpacing: "-0.01em",
                                        lineHeight: 1.2,
                                        whiteSpace: "nowrap",
                                        ...GRAD_TEXT,
                                    }}
                                >
                                    {fmtFull(amount)}
                                </motion.span>
                            </AnimatePresence>
                        </div>
                    </div>

                    {showAutoInvest && (
                        <div
                            style={{
                                display: "flex",
                                alignItems: "center",
                                gap: 12,
                                paddingBottom: 4,
                                flexShrink: 0,
                                flexDirection: isRTL ? "row-reverse" : "row",
                            }}
                        >
                            <span
                                style={{
                                    fontSize: 16,
                                    color: labelColor,
                                    whiteSpace: "nowrap",
                                }}
                            >
                                {labelAutoInvest}
                            </span>
                            <Toggle on={autoOn} onChange={setAutoOn} />
                        </div>
                    )}
                </div>

                {/* ── Slider ─────────────────────────────────────────────── */}
                <PointerSlider
    value={amount}
    min={minAmount}
    max={maxAmount}
    step={100}
    accentColor={accentColor}
    onChange={setAmount}
    isRTL={isRTL}
/>

                <Divider />

                {/* ── You'd earn label ───────────────────────────────────── */}
                <span
                    style={{
                        fontSize: 16,
                        color: labelColor,
                        flexShrink: 0,
                        lineHeight: "140%",
                    }}
                >
                    {labelYoudEarn}
                </span>

                {/* ── Earnings row ───────────────────────────────────────── */}
                <div
                    style={{
                        display: "flex",
                        flexDirection: isMobile ? "column" : "row",
                        width: "100%",
                        flexShrink: 0,
                    }}
                >
                    {earnings.map(({ label, value, uid }, idx) => (
                        <div
                            key={uid}
                            style={{
                                flex: isMobile ? "none" : 1,
                                width: isMobile ? "100%" : undefined,
                                display: "flex",
                                flexDirection: isMobile ? "row" : "column",
                                alignItems: isMobile ? "center" : "flex-start",
                                justifyContent: isMobile
                                    ? "space-between"
                                    : "flex-start",
                                gap: isMobile ? 0 : 8,
                                minWidth: 0,
                                //direction: "ltr",
                                paddingTop: isMobile && idx > 0 ? 14 : 0,
                                paddingBottom: isMobile && idx < 2 ? 14 : 0,
                                borderBottom:
                                    isMobile && idx < 2
                                        ? "1px solid rgba(232,232,232,0.15)"
                                        : "none",
                            }}
                        >
                            <span
                                style={{
                                    fontSize: 16,
                                    color: subLabelColor,
                                    fontWeight: 400,
                                    lineHeight: "140%",
                                    whiteSpace: "nowrap",
                                    order: isMobile ? 0 : 1,
                                }}
                            >
                                {label}
                            </span>
                            <div
                                style={{ order: isMobile ? 1 : 0, minWidth: 0 }}
                            >
                                <AnimNum
                                    value={value}
                                    size={isMobile ? 22 : 28}
                                    iconSize={isMobile ? 14 : 18}
                                    uid={uid}
                                    compact
                                    isRTL={isRTL}
                                />
                            </div>
                        </div>
                    ))}
                </div>

                {/* ── Graph ──────────────────────────────────────────────── */}
                <div
                    style={{
                        flex: 1,
                        minHeight: 60,
                        display: "flex",
                        alignItems: "flex-end",
                        overflow: "hidden",
                    }}
                >
                    <Graph
                        amount={amount}
                        monthlyRate={monthlyRate}
                        autoOn={autoOn}
                        isRTL={isRTL}
                    />
                </div>
            </div>
        </div>
    )
}

